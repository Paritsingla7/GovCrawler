# Copy to deploy/.env and fill in before running docker compose.
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://govcrawler:change-me@db:5432/govcrawler
JWT_SECRET=generate-with-python-c-import-secrets-print-secrets-token-urlsafe-48
CREDENTIAL_ENC_KEY=generate-with-python-c-from-cryptography.fernet-import-Fernet-print-Fernet.generate_key().decode()
DOMAIN=your-domain.example.com

# Least-privilege runtime role (Alembic 0020) — GOVCRAWLER_APP_PASSWORD is only
# read by the `migrate` service, which creates/updates the role; DATABASE_URL_APP
# is what api/dispatcher actually connect with at runtime. Same host/db as
# DATABASE_URL above, different user/password. See deploy/SECURITY.md.
GOVCRAWLER_APP_PASSWORD=change-me-too
DATABASE_URL_APP=postgresql://govcrawler_app:change-me-too@db:5432/govcrawler

# Optional, only set during a JWT_SECRET / CREDENTIAL_ENC_KEY rotation —
# see deploy/SECURITY.md's rotation procedure. Leave unset otherwise.
JWT_SECRET_PREV=
CREDENTIAL_ENC_KEY_PREV=

# Required before a Microsoft/Google SMTP credential can be connected — one-time
# Azure AD / Google Cloud app registration. See .docs/outreach.md and
# .docs/configuration.md. OAUTH_REDIRECT_BASE_URL is derived from DOMAIN above
# (docker-compose.yml); the client id/secret come from the app registration.
OAUTH_MS_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
